#!/bin/sh

# =============================================================================
# WORKTREE DETECTION
# =============================================================================
# In worktrees, .git is a file (not a directory). Feature branches from worktrees
# get CI-tested when merged to preview, so we skip the full test suite here and
# only verify build artifacts exist. This avoids the common failure where worktree
# provisioning produces an incomplete node_modules/dist and the full test suite
# fails on missing dependencies.
# =============================================================================
if [ -f ".git" ]; then
  echo "[pre-push] Worktree detected — running build health check only (CI verifies on merge)"
  # Read health check from services.json if available
  HEALTH_CHECK=""
  CONFIG_FILE=".claude/config/services.json"
  if [ -f "$CONFIG_FILE" ]; then
    HEALTH_CHECK=$(node -e "try{const c=JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8'));if(c.worktreeBuildHealthCheck)console.log(c.worktreeBuildHealthCheck)}catch{}" 2>/dev/null)
  fi
  if [ -n "$HEALTH_CHECK" ]; then
    if eval "$HEALTH_CHECK" 2>/dev/null; then
      echo "[pre-push] Build artifacts present — push allowed"
      exit 0
    fi
    echo "[pre-push] Build artifacts missing — running workspace build..."
    BUILD_CMD=$(node -e "try{const c=JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8'));if(c.worktreeBuildCommand)console.log(c.worktreeBuildCommand)}catch{}" 2>/dev/null)
    if [ -n "$BUILD_CMD" ]; then
      eval "$BUILD_CMD" || { echo "[pre-push] Build failed — push blocked"; exit 1; }
    fi
  fi
  echo "[pre-push] Worktree push allowed"
  exit 0
fi

echo "Running pre-push checks..."
echo ""

# =============================================================================
# FULL TEST SUITE ENFORCEMENT (Every Push — main tree only)
# =============================================================================
# Per CLAUDE.md: "NEVER make tests easier to pass. Tests must validate actual
# behavior under real conditions."
#
# This hook runs the FULL test suite (unit + integration) on every push to
# ensure no broken code reaches the remote repository.
#
# TEST SCOPE PROFILES: When GENTYR_TEST_SCOPE is set (or activeTestScope in
# services.json), all tests still run but only scoped test failures block the
# push. Non-scoped failures produce warnings. This supports vertical slice
# deployment gating without hiding test failures.
# =============================================================================

# Detect active test scope (env var overrides config)
CONFIG_FILE=".claude/config/services.json"
ACTIVE_SCOPE=""
if [ -n "$GENTYR_TEST_SCOPE" ]; then
  ACTIVE_SCOPE="$GENTYR_TEST_SCOPE"
elif [ -f "$CONFIG_FILE" ]; then
  ACTIVE_SCOPE=$(node -e "try{const c=JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8'));if(c.activeTestScope)console.log(c.activeTestScope)}catch{}" 2>/dev/null)
fi

if [ -n "$ACTIVE_SCOPE" ]; then
  # ==========================================================================
  # SCOPE-AWARE PATH: run full suite, re-run scoped subset on failure
  # ==========================================================================
  echo "=============================================="
  echo "FULL TEST SUITE (scope: $ACTIVE_SCOPE)"
  echo "All tests run. Only '$ACTIVE_SCOPE' failures block."
  echo "=============================================="
  echo ""

  echo "Running unit tests..."
  pnpm run test:unit
  UNIT_EXIT=$?
  if [ $UNIT_EXIT -eq 0 ]; then
    echo "Unit tests passed"
  else
    echo "Unit tests had failures (will check scope)"
  fi
  echo ""

  echo "Running integration tests..."
  pnpm run test:integration
  INT_EXIT=$?
  if [ $INT_EXIT -eq 0 ]; then
    echo "Integration tests passed"
  else
    echo "Integration tests had failures (will check scope)"
  fi
  echo ""

  if [ $UNIT_EXIT -eq 0 ] && [ $INT_EXIT -eq 0 ]; then
    echo "=============================================="
    echo "Full test suite passed (scoped and non-scoped)"
    echo "=============================================="
    echo ""
  else
    # Resolve GENTYR framework root via the hooks symlink
    GENTYR_ROOT=$(node -e "try{console.log(require('path').resolve(require('fs').realpathSync('.claude/hooks'),'../..'))}catch{console.log('')}" 2>/dev/null)
    if [ -z "$GENTYR_ROOT" ] || [ ! -f "$GENTYR_ROOT/lib/test-scope-classifier.js" ]; then
      # Fallback: try node_modules/gentyr
      GENTYR_ROOT="node_modules/gentyr"
    fi
    if [ ! -f "$GENTYR_ROOT/lib/test-scope-classifier.js" ]; then
      echo "[pre-push] WARNING: test-scope-classifier.js not found at $GENTYR_ROOT/lib/"
      echo "[pre-push] Fail-closed: cannot classify failures by scope. Push blocked."
      exit 1
    fi

    node "$GENTYR_ROOT/lib/test-scope-classifier.js" \
      --scope "$ACTIVE_SCOPE" \
      --project-dir "$(pwd)" \
      --unit-exit "$UNIT_EXIT" \
      --integration-exit "$INT_EXIT"
    SCOPE_EXIT=$?

    if [ $SCOPE_EXIT -ne 0 ]; then
      exit 1
    fi
    echo ""
  fi
else
  # ==========================================================================
  # ORIGINAL PATH: no scope active — full suite gates (unchanged behavior)
  # ==========================================================================
  echo "=============================================="
  echo "FULL TEST SUITE"
  echo "=============================================="
  echo ""

  echo "Running unit tests..."
  pnpm run test:unit
  UNIT_EXIT=$?

  if [ $UNIT_EXIT -ne 0 ]; then
    echo ""
    echo "Unit tests FAILED. Push blocked."
    echo "   Fix failing tests before pushing."
    exit 1
  fi
  echo "Unit tests passed"
  echo ""

  echo "Running integration tests..."
  pnpm run test:integration
  INT_EXIT=$?

  if [ $INT_EXIT -ne 0 ]; then
    echo ""
    echo "Integration tests FAILED. Push blocked."
    echo "   Fix failing tests before pushing."
    exit 1
  fi
  echo "Integration tests passed"
  echo ""

  echo "=============================================="
  echo "Full test suite passed"
  echo "=============================================="
  echo ""
fi

# =============================================================================
# REPO HYGIENE CHECK (Fire-and-Forget)
# =============================================================================
# Spawns repo-hygiene-expert agent to quickly review project structure.
# This is non-blocking - runs in background after tests pass.
# =============================================================================

echo "Spawning repo-hygiene-expert for quick structure review..."

# Spawn Claude with repo-hygiene-expert agent (fire-and-forget, detached)
nohup claude --dangerously-skip-permissions -p "[Task] Use the repo-hygiene-expert sub-agent for a QUICK pre-push structure review.

## CRITICAL WORKFLOW REQUIREMENTS

This is a PRE-PUSH review. Be CONSERVATIVE and NOT trigger-happy with changes.

### Review Scope (QUICK - focus on critical issues only)
1. Check for obvious architectural violations (cross-product imports violating boundaries)
2. Check for committed build artifacts (dist/, node_modules/)
3. Check for obvious secrets in source files
4. Check root directory cleanliness

### If Issues Found
DO NOT implement fixes yourself. Instead:
1. Document the issues clearly
2. Spawn code-reviewer agent to review your proposed fixes BEFORE implementation
3. Only after code-reviewer approves, spawn code-writer to implement
4. After implementation, spawn code-reviewer AGAIN for final sign-off
5. Finally, spawn project-manager to sync documentation

### If No Issues Found
Simply report that the repository structure looks healthy.

### Remember
- You do NOT have Edit/Write permissions
- Be MEASURED - only flag real violations per your Core Beliefs
- This is a quick check, not a comprehensive audit
- Do not create tasks for minor style issues" > /dev/null 2>&1 &

echo "Repo hygiene check spawned (running in background)"
echo ""

echo "Pre-push checks complete"
exit 0
