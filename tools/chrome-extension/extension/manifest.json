{
  "manifest_version": 3,
  "name": "Gentyr Browser Automation",
  "description": "Browser automation for Gentyr — no auth, no permission prompts",
  "version": "1.0.66",
  "minimum_chrome_version": "116",
  "key": "",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "scripting",
    "debugger",
    "tabGroups",
    "tabs",
    "notifications",
    "system.display",
    "webNavigation",
    "offscreen",
    "nativeMessaging",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "all_frames": true,
      "js": ["assets/accessibility-tree.js-D8KNCIWO.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_start"
    },
    {
      "all_frames": false,
      "js": ["assets/agent-visual-indicator.js-Ct7LqXhp.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_idle"
    },
    {
      "all_frames": false,
      "js": ["assets/demo-interrupt-listener.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:;"
  },
  "icons": {
    "128": "icon-128.png"
  },
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": [
        "assets/accessibility-tree.js-D8KNCIWO.js",
        "assets/agent-visual-indicator.js-Ct7LqXhp.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
